# =============================
# AI Comics Agent — 环境变量示例
# 复制此文件为 .env 并填写真实值
# =============================

# ---------- 模型配置 ----------
# DeepSeek (默认，OpenAI 兼容)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-chat

# 可选：Supervisor 独立模型配置（默认回退到 DEEPSEEK_* / CHAT_MODEL）
SUPERVISOR_API_KEY=
SUPERVISOR_BASE_URL=
SUPERVISOR_MODEL=

# ---------- 图像生成 ----------
# Grok 图像生成（与 ai-comics 后端共用）
IMAGE_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
IMAGE_API_BASE_URL=https://api.x.ai
IMAGE_MODEL=grok-2-image

# ---------- 视频生成 ----------
# 默认复用 IMAGE_API_KEY / IMAGE_API_BASE_URL
VIDEO_API_KEY=
VIDEO_API_BASE_URL=
VIDEO_MODEL=sora-2-reverse
VIDEO_REQUEST_TIMEOUT_MS=120000
VIDEO_POLL_INTERVAL_MS=5000
VIDEO_MAX_WAIT_MS=900000

# ---------- 本地文件存储（开源版默认） ----------
LOCAL_STORAGE_ROOT_DIR=./storage/uploads
LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:3002/storage/uploads
LOCAL_STORAGE_KEY_PREFIX=agent/generated

# ---------- 网络搜索（可选）----------
# Serper.dev (https://serper.dev)，免费额度 2500 次
SERPER_API_KEY=

# Brave Search API (https://brave.com/search/api)
BRAVE_SEARCH_API_KEY=

# ---------- AI Comics 后端 ----------
# Agent 调用 ai-comics 自有接口时需要的配置
COMICS_API_URL=http://localhost:8080
# 从 ai-comics 登录接口获取，用于 Agent 代理用户操作
COMICS_JWT_TOKEN=

# ---------- JWT ----------
# 本服务签发/校验 JWT 的密钥（必填）
JWT_SECRET=replace-with-a-strong-secret

# ---------- 开源版鉴权 ----------
# 账号通过 POST /api/v1/users/register 写入 SQLite（不再通过 env 写死账号）
AUTH_TOKEN_EXPIRES_HOURS=24

# ---------- 服务器 ----------
PORT=3002
# 允许跨域的来源，逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3005

# ---------- 数据库（开源版固定 SQLite） ----------
# SQLite 文件路径（相对 apps/agent-api 运行目录）
SQLITE_PATH=./storage/opensource-manus-agent.sqlite

# ---------- 沙箱 ----------
SANDBOX_IMAGE=ai-comics-sandbox:latest
SANDBOX_MAX_CONTAINERS=5
SANDBOX_MEMORY_LIMIT=384m
SANDBOX_CPU_LIMIT=1
SANDBOX_NETWORK=ai-comics-sandbox-net
SANDBOX_HOST_BASE_URL=http://localhost
SANDBOX_PORT_RANGE_START=32000
SANDBOX_IDLE_TIMEOUT_MS=600000
SANDBOX_CLEANUP_INTERVAL_MS=60000
SANDBOX_WARM_POOL_SIZE=0
SANDBOX_WARM_POOL_REFILL_DELAY_MS=5000
SANDBOX_QUEUE_TIMEOUT_MS=30000
SANDBOX_HEALTH_CHECK_INTERVAL_MS=120000
SANDBOX_HEALTH_CHECK_TIMEOUT_MS=5000
SANDBOX_WORKSPACE_DIR=
SANDBOX_CONTAINER_WORK_DIR=/home/sandbox

# ---------- Skill ----------
# 可选：自定义 skills 根目录（默认自动定位到 src/skills）
SKILLS_DIR=
